services:
  samba:
    image: dperson/samba:latest
    container_name: srv-samba
    restart: unless-stopped
    ports:
      - "139:139"
      - "445:445"
    volumes:
      - /compartido/iso9001:/share/iso9001
      - /compartido/tmp:/share/tmp
    environment:
      - TZ=America/Bogota
    command:
  samba:
   
